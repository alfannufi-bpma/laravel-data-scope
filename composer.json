{
    "name": "alfannufi-bpma/laravel-data-scope",
    "description": "Enterprise Data Scoping Engine for Laravel",
    "type": "library",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/database": "^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Bpma\\DataScope\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Bpma\\DataScope\\ScopeServiceProvider"
            ]
        }
    }
}